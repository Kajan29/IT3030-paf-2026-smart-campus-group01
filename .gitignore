# ==========================
# Zentaritas - Root .gitignore
# Frontend (Vite/React) + Backend (Spring Boot/Maven)
# ==========================

# --- Environment Variables ---
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# --- Node.js / Frontend ---
node_modules/
dist/
dist-ssr/
*.local
.parcel-cache/
.vite/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Java / Spring Boot / Maven ---
target/
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.ear
*.nar

# Maven
.mvn/
mvnw
mvnw.cmd

# Gradle
.gradle/
build/
!gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# --- IDEs and Editors ---
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Eclipse
.project
.classpath
.settings/
.metadata/
bin/
tmp/
*.tmp
*.bak
*.swp
*~.nib

# VS Code
.vscode/
!.vscode/extensions.json

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# --- OS Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --- Logs ---
logs/
*.log

# --- Testing ---
coverage/
*.coverage
.nyc_output/
.cache/

# --- Misc ---
*.temp
*.pid
*.seed
*.pid.lock

main