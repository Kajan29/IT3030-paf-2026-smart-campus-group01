# ==========================
# Root .gitignore for Zentaritas
# Consolidated for frontend (Vite/React) and backend (Spring Boot/Maven)
# ==========================

# --- Node / Frontend ---
node_modules/
dist/
dist-ssr/
/.parcel-cache/
/.vite/

# Vite local envs
.env
.env.*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Java / Backend ---
target/
*.class
*.jar
*.war
*.ear

# Maven
.mvn/
!**/src/main/**/target/
!**/src/test/**/target/

# Gradle
.gradle/
build/

# --- IDEs and Editors ---
.idea/
.vscode/
*.iml
.project
.classpath
.settings/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db

# Misc
*.log
logs/

# Ignore dotenv files (keep examples committed)
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore build output inside frontend and backend
frontend/node_modules/
frontend/dist/
backend/target/

# JetBrains IDE
/.idea/

# Temporary files
*.tmp
*.temp

# Coverage
coverage/
