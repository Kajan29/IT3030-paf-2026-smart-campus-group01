# Frontend Environment Variables
# Copy this file to .env and update with your values

# API Configuration
VITE_API_URL=http://localhost:8080/api
VITE_APP_NAME=Zentaritas

# Google OAuth2 Configuration
# Get your Google Client ID at: https://console.cloud.google.com/apis/credentials
# Make sure to add http://localhost:5173 to authorized JavaScript origins
# and http://localhost:5173 to authorized redirect URIs
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Feature Flags
VITE_ENABLE_ANALYTICS=false
