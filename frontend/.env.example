# Frontend Environment Variables
# Copy this file to .env and update with your values

# API Configuration
VITE_API_URL=/api
VITE_APP_NAME=Smart Campus
VITE_SESSION_TIMEOUT_MINUTES=30

# Google OAuth2 Configuration
# Get your Google Client ID at: https://console.cloud.google.com/apis/credentials
# Make sure to add http://localhost:5173 to authorized JavaScript origins
# and http://localhost:5173 to authorized redirect URIs
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# OpenAI Ticket Assistant
# Create API key: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your-openai-api-key
VITE_OPENAI_MODEL=gpt-4.1-mini
VITE_OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Feature Flags
VITE_ENABLE_ANALYTICS=false
